                <div class="mockup-chart-bar" style="height:72%"><span>2029</span></div>
                <div class="mockup-chart-bar" style="height:82%"><span>2030</span></div>
                <div class="mockup-chart-bar highlight" style="height:95%"><span>2031</span></div>
