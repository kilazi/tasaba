<!-- Barrios preview -->
<section class="section">
  <div class="container">
    <div class="section-center">
      <h2 class="section-title">Barrios que cubrimos</h2>
      <p class="section-desc">Datos de mercado actualizados para cada zona de Buenos Aires.</p>
    </div>
    <div class="barrios-preview">
      <% neighborhoods.slice(0, 6).forEach(n => { %>
      <a href="/barrio/<%= n.slug %>" class="barrio-pill">
        <span class="barrio-pill-name"><%= n.name %></span>
        <span class="barrio-pill-zone"><%= n.zone %></span>
      </a>
      <% }) %>
      <a href="/ranking" class="barrio-pill barrio-pill-more">
        +<%= neighborhoods.length - 6 %> barrios mas
      </a>
