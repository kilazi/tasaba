              <div class="mockup-bar-marker" style="left:72%"></div>
            </div>
            <div class="mockup-metrics">
              <div class="mockup-metric"><span class="mockup-metric-val accent">82/100</span><span class="mockup-metric-label">Demanda</span></div>
              <div class="mockup-metric"><span class="mockup-metric-val green">Optimo</span><span class="mockup-metric-label">Mercado</span></div>
