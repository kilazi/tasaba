              <div class="mockup-section-title">Estrategia</div>
              <div class="mockup-strategy-badge">Vender ahora — Confianza Alta</div>
            </div>
            <div class="mockup-section">
              <div class="mockup-section-title">Sell vs Rent</div>
              <div class="mockup-pills">
                <span class="mockup-pill sell">Vender $158K</span>
                <span class="mockup-pill short">Temp. $1,820/m</span>
                <span class="mockup-pill long">Trad. $680/m</span>
