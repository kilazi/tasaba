<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Evaluar propiedad — TasaBA</title>
  <meta name="description" content="Evalua tu propiedad en Buenos Aires con inteligencia artificial. Gratis, rapido y basado en datos de mercado actuales.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%231a365d'/><path d='M6 18l10-10 10 10' stroke='white' stroke-width='2.5' fill='none'/><rect x='12' y='16' width='8' height='10' rx='1' fill='white' opacity='.9'/><rect x='14' y='18' width='4' height='4' rx='.5' fill='%231a365d'/></svg>">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TASABA01"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-TASABA01');</script>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <svg class="nav-logo" width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="6" fill="#1a365d"/>
        <path d="M6 18l10-10 10 10" stroke="white" stroke-width="2.5" fill="none"/>
        <rect x="12" y="16" width="8" height="10" rx="1" fill="white" opacity=".9"/>
        <rect x="14" y="18" width="4" height="4" rx=".5" fill="#1a365d"/>
      </svg>
      TasaBA
    </a>
    <button class="nav-toggle" onclick="this.nextElementSibling.classList.toggle('open')" aria-label="Menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>
    <div class="nav-links">
      <a href="/">Inicio</a>
      <a href="/precios">Precios</a>
    </div>
  </div>
</nav>

<section class="section" style="padding-top:40px">
  <div class="container" style="max-width:760px">

    <!-- Step 1: Input form -->
    <div id="step-input">
      <h1 style="font-size:28px;font-weight:700;margin-bottom:6px">Evaluar propiedad</h1>
      <p style="color:var(--text-secondary);margin-bottom:32px">Completa los datos de tu propiedad. Resultado en menos de un minuto.</p>

      <form id="evalForm" enctype="multipart/form-data">
        <!-- Property details FIRST -->
        <div class="form-group">
          <label class="form-label">Direccion</label>
          <input class="form-input" name="address" type="text" placeholder="Ej: Av. Rivadavia 5200, Caballito">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Barrio</label>
            <select class="form-select" name="neighborhood" required>
              <option value="">Seleccionar</option>
              <% neighborhoods.forEach(n => { %>
              <option value="<%= n.slug %>"><%= n.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Superficie (m2)</label>
            <input class="form-input" name="m2" type="number" min="15" max="500" value="45" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Tipologia</label>
            <select class="form-select" name="typology">
              <option value="monoambiente">Monoambiente</option>
              <option value="dosAmbientes" selected>2 ambientes</option>
              <option value="tresAmbientes">3 ambientes</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Piso (opcional)</label>
            <input class="form-input" name="floor" type="text" placeholder="Ej: 8">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Amenities (selecciona las que aplican)</label>
          <div class="amenities-chips" id="amenitiesChips">
            <label class="chip"><input type="checkbox" name="amenity" value="balcon"><span>Balcon</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="cochera"><span>Cochera</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="pileta"><span>Pileta</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="sum"><span>SUM</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="laundry"><span>Laundry</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="terraza"><span>Terraza</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="gimnasio"><span>Gimnasio</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="seguridad"><span>Seguridad 24h</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="baulera"><span>Baulera</span></label>
            <label class="chip"><input type="checkbox" name="amenity" value="parrilla"><span>Parrilla</span></label>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Notas adicionales <span style="font-weight:400;color:var(--text-muted)">(opcional)</span></label>
          <textarea class="form-input" name="notes" rows="2" placeholder="Ej: reciclado a nuevo, vista al parque, a metros del subte, ultimo piso..." style="resize:vertical"></textarea>
        </div>

        <!-- Condition quiz -->
        <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border-light)">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <label class="form-label" style="margin-bottom:0">Condicion del inmueble</label>
            <span style="font-size:11px;color:var(--accent);background:var(--accent-bg);padding:2px 8px;border-radius:10px;font-weight:600">Mejora la precision</span>
          </div>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:16px">Se honesto — cada respuesta ajusta el precio. El comprador va a encontrar estos problemas igual.</p>

          <div class="quiz-grid">
            <div class="form-group">
              <label class="form-label">Antiguedad del edificio</label>
              <select class="form-select" name="buildingAge">
                <option value="">No se</option>
                <option value="0-5">Menos de 5 anos</option>
                <option value="5-15">5 a 15 anos</option>
                <option value="15-30">15 a 30 anos</option>
                <option value="30-50">30 a 50 anos</option>
                <option value="50+">Mas de 50 anos</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Humedad</label>
              <select class="form-select" name="humidity">
                <option value="">No se</option>
                <option value="none">Sin humedad</option>
                <option value="mild">Leve (manchas pequeñas)</option>
                <option value="moderate">Moderada (paredes afectadas)</option>
                <option value="severe">Severa (estructural)</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Instalacion de gas reemplazada?</label>
              <select class="form-select" name="gasReplaced">
                <option value="">No se</option>
                <option value="yes">Si, renovada</option>
                <option value="no">No, original</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Cocina</label>
              <select class="form-select" name="kitchen">
                <option value="">No se</option>
                <option value="excellent">Excelente (renovada)</option>
                <option value="good">Buena</option>
                <option value="fair">Regular</option>
                <option value="needs_renovation">Necesita renovacion</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Bano principal</label>
              <select class="form-select" name="bathroom">
                <option value="">No se</option>
                <option value="excellent">Excelente (renovado)</option>
                <option value="good">Bueno</option>
                <option value="fair">Regular</option>
                <option value="needs_renovation">Necesita renovacion</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Estado de pisos</label>
              <select class="form-select" name="floors">
                <option value="">No se</option>
                <option value="excellent">Excelente</option>
                <option value="good">Bueno</option>
                <option value="fair">Regular</option>
                <option value="needs_renovation">Necesitan renovacion</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Luz natural</label>
              <select class="form-select" name="naturalLight">
                <option value="">No se</option>
                <option value="abundant">Abundante (contrafrente alto)</option>
                <option value="good">Buena</option>
                <option value="limited">Limitada (piso bajo/interno)</option>
                <option value="poor">Pobre (muy oscuro)</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Mantenimiento general</label>
              <select class="form-select" name="maintenance">
                <option value="">No se</option>
                <option value="excellent">Excelente (impecable)</option>
                <option value="good">Bueno</option>
                <option value="fair">Regular</option>
                <option value="poor">Deficiente</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Photos OPTIONAL below -->
        <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border-light)">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
            <label class="form-label" style="margin-bottom:0">Fotos del interior</label>
            <span style="font-size:11px;color:var(--text-muted);background:var(--surface-alt);padding:2px 8px;border-radius:10px">Opcional</span>
          </div>
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px">Mejora tu valuacion con fotos. La IA analiza condicion, terminaciones y estilo para ajustar el precio.</p>
          <div class="photo-suggestions">
            <span>Fotos recomendadas:</span>
            <span class="photo-tag">Living/comedor</span>
            <span class="photo-tag">Cocina</span>
            <span class="photo-tag">Bano principal</span>
            <span class="photo-tag">Dormitorio</span>
            <span class="photo-tag">Vista desde balcon</span>
          </div>
          <div class="upload-zone upload-zone-compact" id="uploadZone">
            <input type="file" id="photoInput" name="photos" multiple accept="image/*" style="display:none">
            <div class="upload-content" id="uploadContent">
              <svg width="28" height="28" fill="none" stroke="var(--text-muted)" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <p style="margin-top:8px;font-weight:500;font-size:14px">Arrastra fotos o hace click</p>
              <p style="font-size:12px;color:var(--text-muted)">Hasta 5 fotos. Mientras mas ambientes muestres, mejor la valuacion.</p>
            </div>
            <div id="photoPreview" class="photo-preview" style="display:none"></div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg" style="margin-top:24px" id="evalBtn">
          Evaluar propiedad
        </button>
        <p style="font-size:12px;color:var(--text-muted);text-align:center;margin-top:8px">
          Las fotos no se almacenan. Solo se usan para el analisis.
        </p>
      </form>
    </div>

    <!-- Step 2: Loading -->
    <div id="step-loading" style="display:none;text-align:center;padding:80px 0">
      <div class="loader"></div>
      <h2 style="margin-top:24px;font-size:20px">Analizando tu propiedad...</h2>
      <p style="color:var(--text-secondary);margin-top:8px">Cruzando datos de mercado y generando tu informe.</p>
      <div style="margin-top:32px;text-align:left;max-width:320px;margin-left:auto;margin-right:auto">
        <div class="loading-step active" id="ls-1"><span class="loading-dot"></span> Analizando datos del barrio...</div>
        <div class="loading-step" id="ls-2"><span class="loading-dot"></span> Calculando valuacion de mercado</div>
        <div class="loading-step" id="ls-3"><span class="loading-dot"></span> Generando proyecciones</div>
        <div class="loading-step" id="ls-4"><span class="loading-dot"></span> Analizando estrategia de venta</div>
        <div class="loading-step" id="ls-5"><span class="loading-dot"></span> Preparando informe</div>
      </div>
    </div>

    <!-- Step 3: Teaser result -->
    <div id="step-teaser" style="display:none">
      <div class="teaser-result">
        <div class="teaser-header">
          <h2>Valuacion estimada</h2>
          <div class="teaser-neighborhood" id="teaser-neighborhood"></div>
        </div>

        <div class="teaser-price-box">
          <div class="teaser-price" id="teaser-price"></div>
          <div class="teaser-range" id="teaser-range"></div>
          <div id="teaser-real-value" style="display:none">
            <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border-light)">
              <div style="font-size:12px;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);margin-bottom:4px">Valor real de mercado</div>
              <div style="font-size:1.8rem;font-weight:800;color:var(--green)" id="teaser-real-price"></div>
              <div style="font-size:12px;color:var(--text-muted);margin-top:4px;max-width:400px;margin-left:auto;margin-right:auto" id="teaser-real-context"></div>
            </div>
          </div>
        </div>

        <div id="teaser-condition-adj" style="display:none;padding:12px 28px">
          <div style="background:var(--accent-bg);border-radius:var(--radius-sm);padding:12px 16px;display:flex;align-items:center;gap:10px">
            <svg width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
            <span style="font-size:13px;color:var(--accent)" id="teaser-condition-text"></span>
          </div>
        </div>

        <div class="teaser-details" id="teaser-details"></div>

        <!-- Blurred gate — report content -->
        <div class="gate-section">
          <div class="gate-blur">
            <div class="gate-fake-row"><strong>Estrategia:</strong> Vender ahora vs esperar — analisis de mercado con proyeccion a 1, 3 y 5 anos</div>
            <div class="gate-fake-row"><strong>Analisis:</strong> Vender vs alquiler temporario vs alquiler tradicional — rendimiento comparado</div>
            <div class="gate-fake-row"><strong>Renovacion:</strong> Renovar vs vender asi — ROI estimado por tipo de mejora</div>
            <div class="gate-fake-row"><strong>IA:</strong> Evaluacion detallada de condicion, terminaciones, positivos y negativos</div>
            <div class="gate-fake-row"><strong>Mercado:</strong> Ranking del barrio, comparacion con 3 barrios similares, insight competitivo</div>
            <div class="gate-fake-row"><strong>Perfil:</strong> Comprador objetivo identificado, tiempo estimado de venta, margen de negociacion</div>
          </div>
          <div class="gate-overlay">
            <h3>Informe completo</h3>
            <p>Dejanos tu contacto para recibir el analisis completo con estrategia de venta, proyecciones y recomendaciones.</p>
            <form id="unlockForm">
              <input type="hidden" name="evalId" id="evalId">
              <div class="form-group">
                <input class="form-input" name="name" placeholder="Tu nombre" required>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <input class="form-input" name="whatsapp" placeholder="WhatsApp (ej: 11-XXXX-XXXX)">
                </div>
                <div class="form-group">
                  <input class="form-input" name="email" type="email" placeholder="Email">
                </div>
              </div>
              <button type="submit" class="btn btn-primary btn-block">Recibir informe completo</button>
              <p style="font-size:12px;color:var(--text-muted);text-align:center;margin-top:6px">Te lo enviamos al instante. Sin spam.</p>
            </form>
          </div>
        </div>

        <!-- Premium features teaser -->
        <div class="premium-teaser">
          <div class="premium-header">
            <span class="premium-badge">Proximamente</span>
            <h3>TasaBA Premium</h3>
          </div>
          <div class="premium-features">
            <div class="premium-feature">
              <div class="premium-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </div>
              <div>
                <strong>Forecasting avanzado</strong>
                <p>Predicciones de precio por m2 con modelos de tendencia, estacionalidad y factores macro</p>
              </div>
            </div>
            <div class="premium-feature">
              <div class="premium-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <strong>Propuesta de mejor deal</strong>
                <p>La IA te dice la estrategia optima: "alquila ahora y vende en 3 anos" con simulacion de ingresos completa</p>
              </div>
            </div>
            <div class="premium-feature">
              <div class="premium-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <div>
                <strong>Monitoreo y alertas de mercado</strong>
                <p>Alertas cuando cambia el precio en tu zona, aparece competencia o se mueve la demanda</p>
              </div>
            </div>
            <div class="premium-feature">
              <div class="premium-icon">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <div>
                <strong>Inmobiliarias sugeridas + staging IA</strong>
                <p>Top 3 inmobiliarias de tu zona, pack de fotos mejoradas y staging virtual para tu publicacion</p>
              </div>
            </div>
          </div>
          <form id="waitlistForm" class="premium-waitlist">
            <input class="form-input" name="waitlist_email" type="email" placeholder="Tu email para la lista de espera">
            <button type="submit" class="btn btn-outline btn-sm">Sumarme a la lista</button>
          </form>
          <p style="font-size:12px;color:var(--text-muted);text-align:center;margin-top:6px">Seras de los primeros en acceder cuando lancemos Premium.</p>
        </div>
      </div>

      <div style="text-align:center;margin-top:24px">
        <a href="/evaluar" class="btn btn-outline">Evaluar otra propiedad</a>
      </div>
    </div>

    <!-- Step 4: Full report unlocked -->
    <div id="step-full" style="display:none">
      <div class="full-report" id="full-report"></div>

      <!-- Premium teaser after full report too -->
      <div class="premium-teaser" style="margin-top:20px">
        <div class="premium-header">
          <span class="premium-badge">Proximamente</span>
          <h3>TasaBA Premium</h3>
        </div>
        <div class="premium-features">
          <div class="premium-feature">
            <div class="premium-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div>
              <strong>Forecasting avanzado + propuesta de mejor deal</strong>
              <p>La IA simula todos los escenarios y te recomienda la estrategia optima con proyeccion de ingresos</p>
            </div>
          </div>
          <div class="premium-feature">
            <div class="premium-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <strong>Monitoreo de mercado + inmobiliarias + staging IA</strong>
              <p>Alertas de precios, top inmobiliarias de tu zona, fotos profesionales y staging virtual</p>
            </div>
          </div>
        </div>
        <form class="premium-waitlist" onsubmit="event.preventDefault();saveWaitlist(this);showToast('Te sumamos a la lista. Te avisamos cuando lance!');">
          <input class="form-input" name="waitlist_email" type="email" placeholder="Tu email para la lista de espera">
          <button type="submit" class="btn btn-outline btn-sm">Sumarme</button>
        </form>
      </div>

      <div style="text-align:center;margin-top:24px">
        <a href="/evaluar" class="btn btn-primary">Evaluar otra propiedad</a>
      </div>
    </div>

  </div>
</section>

<div class="toast" id="toast"></div>

<script>
const fmt = n => n.toLocaleString('en-US');
let currentEvalId = null;
let currentAddress = '';

// Pre-select barrio from URL param
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('barrio')) {
  const sel = document.querySelector('[name="neighborhood"]');
  if (sel) sel.value = urlParams.get('barrio');
}

// Photo upload
const zone = document.getElementById('uploadZone');
const input = document.getElementById('photoInput');
const preview = document.getElementById('photoPreview');
const content = document.getElementById('uploadContent');
let selectedFiles = [];

zone.addEventListener('click', () => input.click());
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
zone.addEventListener('drop', e => {
  e.preventDefault(); zone.classList.remove('drag-over');
  handleFiles(e.dataTransfer.files);
});
input.addEventListener('change', () => handleFiles(input.files));

function handleFiles(files) {
  const arr = Array.from(files).filter(f => f.type.startsWith('image/')).slice(0, 5);
  if (!arr.length) return;
  selectedFiles = arr;
  content.style.display = 'none';
  preview.style.display = 'flex';
  preview.innerHTML = '';
  arr.forEach((f, i) => {
    const reader = new FileReader();
    reader.onload = e => {
      const div = document.createElement('div');
      div.className = 'photo-thumb';
      div.innerHTML = `<img src="${e.target.result}"><button type="button" onclick="removePhoto(${i})" class="photo-remove">x</button>`;
      preview.appendChild(div);
    };
    reader.readAsDataURL(f);
  });
}

function removePhoto(i) {
  selectedFiles.splice(i, 1);
  if (!selectedFiles.length) {
    content.style.display = '';
    preview.style.display = 'none';
  } else {
    handleFiles(selectedFiles);
  }
}

// Loading animation
function animateLoading() {
  const steps = ['ls-1','ls-2','ls-3','ls-4','ls-5'];
  let i = 0;
  const iv = setInterval(() => {
    if (i > 0) document.getElementById(steps[i-1]).classList.add('done');
    if (i < steps.length) document.getElementById(steps[i]).classList.add('active');
    i++;
    if (i > steps.length) clearInterval(iv);
  }, 1200);
  return iv;
}

// Submit evaluation
document.getElementById('evalForm').addEventListener('submit', async e => {
  e.preventDefault();
  const form = e.target;
  const fd = new FormData(form);

  // Collect amenities from chips
  const amenities = Array.from(document.querySelectorAll('[name="amenity"]:checked')).map(c => c.value).join(', ');
  fd.delete('amenity');
  fd.set('amenities', amenities);

  fd.delete('photos');
  selectedFiles.forEach(f => fd.append('photos', f));

  document.getElementById('step-input').style.display = 'none';
  document.getElementById('step-loading').style.display = '';
  const loadingIv = animateLoading();

  try {
    const res = await fetch('/api/evaluate', { method: 'POST', body: fd });
    const data = await res.json();
    clearInterval(loadingIv);
    if (!data.ok) throw new Error(data.error);
    showTeaser(data);
  } catch(err) {
    clearInterval(loadingIv);
    showToast('Error: ' + err.message);
    document.getElementById('step-loading').style.display = 'none';
    document.getElementById('step-input').style.display = '';
  }
});

function showTeaser(data) {
  document.getElementById('step-loading').style.display = 'none';
  document.getElementById('step-teaser').style.display = '';

  const t = data.teaser;
  currentEvalId = data.evalId;
  currentAddress = document.querySelector('[name="address"]').value || t.neighborhood;
  document.getElementById('teaser-neighborhood').textContent = t.neighborhood + ' — ' + t.zone;
  document.getElementById('teaser-price').innerHTML = `<span style="font-size:12px;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);display:block;margin-bottom:4px">Precio de publicacion</span>USD $${fmt(t.estimatedPrice)}`;
  document.getElementById('teaser-range').innerHTML = `<span>$${fmt(t.priceRange.low)}</span> — <span>$${fmt(t.priceRange.high)}</span>`;
  document.getElementById('evalId').value = data.evalId;

  // Show real market value
  if (t.realValue) {
    const rv = document.getElementById('teaser-real-value');
    rv.style.display = '';
    document.getElementById('teaser-real-price').textContent = 'USD $' + fmt(t.realValue);
    document.getElementById('teaser-real-context').textContent = t.realValueContext;
  }

  // Show condition quiz adjustment
  if (t.hasQuiz && t.conditionAdj !== 0) {
    const adj = document.getElementById('teaser-condition-adj');
    adj.style.display = '';
    document.getElementById('teaser-condition-text').textContent =
      `Ajuste por condicion del inmueble: ${t.conditionAdj > 0 ? '+' : ''}${t.conditionAdj}% aplicado a la valuacion`;
  }

  let details = '';
  details += `<div class="teaser-detail-row"><span>Promedio del barrio</span><strong>$${fmt(t.neighborhoodAvg)}/m2</strong></div>`;
  details += `<div class="teaser-detail-row"><span>Tendencia anual</span><strong class="trend-up">+${t.trend}%</strong></div>`;
  details += `<div class="teaser-detail-row"><span>Mercado</span><strong>${t.marketTiming}</strong></div>`;
  details += `<div class="teaser-detail-row"><span>Demanda</span><strong>${t.demandScore}/100</strong></div>`;
  details += `<div class="teaser-detail-row"><span>Tiempo est. de venta</span><strong>${t.timeToSell}</strong></div>`;
  details += `<div class="teaser-detail-row"><span>Recomendacion</span><strong style="color:var(--accent)">${t.sellRecommendation}</strong></div>`;
  if (t.condition) details += `<div class="teaser-detail-row"><span>Condicion (IA)</span><strong>${t.condition}</strong></div>`;
  if (t.style) details += `<div class="teaser-detail-row"><span>Estilo (IA)</span><strong>${t.style}</strong></div>`;
  if (t.adjustment) details += `<div class="teaser-detail-row"><span>Ajuste IA fotos</span><strong>${t.adjustment > 0 ? '+' : ''}${t.adjustment}%</strong></div>`;
  document.getElementById('teaser-details').innerHTML = details;
}

// Unlock full report
document.getElementById('unlockForm').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = Object.fromEntries(new FormData(e.target));
  if (!fd.whatsapp && !fd.email) { showToast('Ingresa WhatsApp o email'); return; }

  const btn = e.target.querySelector('button');
  btn.textContent = 'Generando...';
  btn.disabled = true;

  try {
    const res = await fetch('/api/unlock', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(fd)
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error);
    showFullReport(data.report);
  } catch(err) {
    showToast('Error: ' + err.message);
    btn.textContent = 'Recibir informe completo';
    btn.disabled = false;
  }
});

